{
  "name": "@skland-utils/monorepo",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "prepare": "simple-git-hooks",
    "build": "rimraf packages/*/dist --glob && pnpm -r --filter=./packages/* run build",
    "test": "vitest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.11.0",
    "@antfu/ni": "^24.3.0",
    "@types/eslint": "^9.6.1",
    "eslint": "^9.23.0",
    "lint-staged": "^15.5.0",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.12.1",
    "typescript": "^5.8.2",
    "unbuild": "^3.5.0",
    "vitest": "^3.0.9"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
